<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 p-10 text-white">
        <h3>Create User</h3>
        <form action="/create" method="post" class="mt-3">

            <input class="px-3 py-3 rounded-md bg-transparent border-2  border-zinc-800" type="text" placeholder="Enter name" name ="username">
            <input class="px-3 py-3 rounded-md bg-transparent border-2  border-zinc-800" type="email" placeholder="Enter email" name="email">
            <input class="px-3 py-3 rounded-md bg-transparent border-2  border-zinc-800" type="password" placeholder="Enter password" name="password">
            <input class="px-3 py-3 rounded-md bg-transparent border-2  border-zinc-800" type="age" placeholder="Enter age" name="age">
            <input type="submit" class="px-5 py-2 rounded-md bg-blue-500 " value="Create User">
        </form>


    </div>

</body>
</html>