<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>

    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <a href="/logout" class="bg-red-500 inline-block px-3 py-2 text-sm mb-5 outline-none rounded-md">Logout</a>
        <h3 class="text-3xl mb-5 "> 
           <span class="font-light"> Hello </span>, <%=user.name%>👋</h3>
        <h5 class="mb-5"> Create your post here</h5>
        <form action="">
            
            <textarea placeholder="what's on your mind?" class=" p-3 w-1/3 resize-none outline-none bg-transparent border-2 border-zinc-800 rounded-md block">
            </textarea>
            <input type="submit" class="outline-none w-40 bg-blue-800 rounded-md px-3 py-2 block mt-2 text-sm" value="Create your post">


        </form>
    </div>
    
</body>
</html>